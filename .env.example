# Scraping timeouts and cache TTLs
SCRAPE_TIMEOUT_SECONDS=45
PROFILE_CACHE_TTL_SECONDS=900
SEARCH_CACHE_TTL_SECONDS=900
COMMENTS_CACHE_TTL_SECONDS=900

# Set to "true" in production (HTTPS required for secure cookies)
COOKIE_SECURE=true

# Supabase – get these from your Supabase project → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mayar checkout URLs – create a product/checkout page for each plan in Mayar dashboard
MAYAR_URL_STARTER=
MAYAR_URL_PRO=
MAYAR_URL_LIFETIME=
MAYAR_WEBHOOK_SECRET=

# Optional: TikTok session cookie for authenticated scraping (avoids geo-blocks)
TIKTOK_COOKIE=
